# ─── 应用配置 ──────────────────────────────────────────────────
APP_NAME=AutoChatGPT Manager
DEBUG=false

# ─── JWT 安全密钥（生产环境必须修改）─────────────────────────
SECRET_KEY=change-this-very-secret-key-in-production

# ─── 注册超时（秒）────────────────────────────────────────────
REGISTRATION_TIMEOUT=120

# ─── 自动化开关 ─────────────────────────────────────────────────
# 启用后允许自动注册 ChatGPT 账号（需安装 requirements-unsupported-automation.txt）
ENABLE_UNSUPPORTED_AUTOMATION=true

# ─────────────────────────────────────────────────────────────────
# 以下配置均可在前端「域名邮箱 → 系统配置」页面中设置，
# 首次启动时会自动将 .env 中的值迁移到数据库，后续从数据库读取。
# ─────────────────────────────────────────────────────────────────

# ─── 域名（用于生成域名邮箱别名）────────────────────────────
DOMAIN_NAME=yourdomain.com

# ─── IMAP 收信设置 ────────────────────────────────────────────
IMAP_HOST=imap.163.com
IMAP_PORT=993
IMAP_USER=yourmail@163.com
IMAP_PASSWORD=your_imap_auth_code

# ─── 代理配置（可选，注册时使用）─────────────────────────────
# PROXY_HOST=127.0.0.1
# PROXY_PORT=7890
# PROXY_USER=
# PROXY_PASS=
